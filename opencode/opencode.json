{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "autoupdate": true,
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "gh pr *": "allow",
      "git add *": "deny",
      "git reset *": "deny",
      "rm *": "deny"
    },
    "skill": {
      "*": "allow",
      "internal-*": "deny",
      "experimental-*": "ask"
    }
  },
  "plugin": [
    "@dietrichgebert/ponytail",
    "@omniroute/opencode-provider"
  ]
}
