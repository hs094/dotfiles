{
  "$schema" : "https:\/\/raw.githubusercontent.com\/manaflow-ai\/cmux\/main\/web\/data\/cmux.schema.json",
  "app" : {
    "minimalMode" : true,
    "openMarkdownInCmuxViewer" : true,
    "preferredEditor" : "nvim"
  },
  "automation" : {
    "claudeBinaryPath" : "",
    "claudeCodeIntegration" : true,
    "cursorIntegration" : true,
    "geminiIntegration" : true,
    "portBase" : 9100,
    "portRange" : 10,
    "socketControlMode" : "cmuxOnly"
  },
  "browser" : {
    "defaultSearchEngine" : "custom",
    "customSearchEngineName" : "unduck",
    "customSearchEngineURLTemplate" : "https:\/\/unduck.link?q=%s"
  },
  "schemaVersion" : 1,
  "shortcuts" : {
    "bindings" : {
      "focusRightSidebar" : "cmd+shift+\\",
      "toggleSidebar" : "cmd+\\"
    }
  },
  "terminal" : {
    "autoResumeAgentSessions" : true,
    "showScrollBar" : true
  }
}