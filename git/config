[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[user]
	name = hs094
	email = iamhardikat11@gmail.com

[credential]
	helper = osxkeychain

[init]
	defaultBranch = main

[core]
	excludesfile = ~/.config/git/.gitignore_global
	editor = nvim
	fsmonitor = true

[status]
	branch = true
	showStash = true
	showUntrackedFiles = all

[diff]
	context = 3
	renames = true
	interHunkContext = 10
	algorithm = histogram

[pager]
	diff = delta

[delta]
	navigate = true
	dark = true
	side-by-side = false
	line-numbers = true

[color "diff"]
	meta = black bold
	frag = magenta
	context = white
	whitespace = yellow reverse
	old = red

[merge]
	conflictStyle = zdiff3

[push]
	autoSetupRemote = true
	default = current
	followTags = true

[pull]
	default = current
	rebase = true

[fetch]
	prune = true

[rebase]
	autoStash = true
	missingCommitsCheck = warn
	updateRefs = true

[protocol]
	version = 2

[branch]
	sort = -committerdate

[rerere]
	enabled = true

[url "git@github.com:hs094/"]
	insteadOf = hs:

[url "git@github.com:"]
	insteadOf = gh:

[url "git@github.com:Tailored-AI-Hub/"]
	insteadOf = tai:

[alias]
	commit-at = "!f() { \
	  TS=$(date -j -f \"%Y-%m-%d %H:%M:%S\" \"$1\" \"+%Y-%m-%dT%H:%M:%S\"); \
	  GIT_AUTHOR_DATE=\"$TS\" GIT_COMMITTER_DATE=\"$TS\" git commit -m \"$2\"; \
	}; f"
	prune-gone = "!git config --global --get alias.prune-gone fetch --prune && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs -r git branch -D"

